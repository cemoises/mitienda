# Supabase — panel Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Clave "service_role" (Project Settings > API > service_role secret). NUNCA
# le pongas el prefijo NEXT_PUBLIC_ ni la expongas al cliente: bypassea RLS
# por completo. La usan los repositorios server-side para leer/escribir
# orders y para escribir products (ver supabase/schema.sql).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Panel /admin — sin esta variable, /admin/* queda inaccesible (fail closed),
# no hay fallback inseguro. Elegí una contraseña larga y única.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Skrill — merchant.skrill.com > Settings > Developer settings (Quick Checkout)
SKRILL_PAY_TO_EMAIL=pagos@cemoises.com
SKRILL_MERCHANT_ID=demo-merchant-id
SKRILL_SECRET_WORD=demo-secret-word

# Resend — resend.com/api-keys (emails transaccionales de confirmacion de orden)
RESEND_API_KEY=re_your_api_key
# Remitente verificado en Resend. "onboarding@resend.dev" funciona para pruebas
# sin necesidad de verificar un dominio propio.
RESEND_FROM_EMAIL="PARABOX <onboarding@resend.dev>"
# Correo interno que recibe la alerta de cada nueva venta.
ADMIN_EMAIL=admin@cemoises.com
