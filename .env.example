# Supabase — panel Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# PayPal — developer.paypal.com > My Apps & Credentials
# "sb" es el Client ID público de PayPal Sandbox: sirve como fallback de demo
# sin romper el build si todavía no configuraste tu propia app de PayPal.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=sb
